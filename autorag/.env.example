# =============================================================================
# AutoRAG 환경변수 — 복사해서 .env 로 사용
# =============================================================================
# vLLM 또는 Ollama 가 OpenAI 호환 API 를 노출하면 외부 통신 없음.

# ---- LLM endpoint (모두 로컬) ----
OPENAI_API_KEY=EMPTY
# Linux 서버(vLLM):
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# Windows 개발기(Ollama):
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# ---- HuggingFace 캐시 (운영망 반입 후 OFFLINE) ----
HF_HOME=./hf_cache
# 망분리 환경에서 활성화:
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# ---- (선택) 한국어 OCR 경로 ----
# Windows: tessdata 위치
# TESSDATA_PREFIX=C:\Program Files\Tesseract-OCR\tessdata
