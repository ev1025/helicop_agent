# 이 파일을 .env 로 복사한 뒤 값을 채우세요. .env 는 .gitignore 됨.
# 서버 시작 시 app/api/main.py 가 load_dotenv() 로 읽음.

# ── Langfuse trace (선택, 없으면 trace 비활성화 = no-op) ──
# https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── agent_v2 LLM 백엔드 (선택, 기본 gguf) ──
# gguf = Qwen2.5-7B GGUF Q4_K_M (llama.cpp, 권장) / bnb = bitsandbytes 4bit (느림, 디버깅용)
# CHAT_V2_BACKEND=gguf
# AGENT_V2_BACKEND=gguf
